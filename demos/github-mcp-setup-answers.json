{
  "bundle_source": ".",
  "env": "dev",
  "greentic_setup_version": "1.0.0",
  "platform_setup": {
    "deployment_targets": [],
    "static_routes": {
      "default_route_prefix_policy": "pack_declared",
      "public_surface_policy": "disabled",
      "public_web_enabled": false,
      "tenant_path_policy": "pack_declared"
    }
  },
  "setup_answers": {
    "messaging-webchat-gui": {
      "mode": "local_queue",
      "public_base_url": "http://localhost:8080",
      "route": "webchat"
    },
    "messaging-webchat": {
      "enabled": true,
      "jwt_signing_key": "secret",
      "mode": "local_queue",
      "public_base_url": "http://localhost:8080",
      "route": "webchat"
    },
    "oauth-oidc-generic": {
      "provider_id": "github",
      "auth_url": "https://github.com/login/oauth/authorize",
      "token_url": "https://github.com/login/oauth/access_token",
      "public_base_url": "http://localhost:8080",
      "client_id": "",
      "client_secret": "",
      "client_id_key": "OAUTH_CLIENT_ID",
      "client_secret_key": "OAUTH_CLIENT_SECRET",
      "default_scopes": "repo security_events"
    },
    "state-memory": {}
  },
  "team": null,
  "tenant": "demo"
}
