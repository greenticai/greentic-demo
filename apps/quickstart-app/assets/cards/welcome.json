{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "greentic": {
    "cardId": "welcome",
    "flow": "on_message"
  },
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://raw.githubusercontent.com/microsoft/adaptive-cards/main/assets/ic_support.png",
                  "size": "Medium",
                  "altText": "$t(quickstart_app.welcome.body_0.items_0.columns_0.items_0.altText)"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$t(quickstart_app.welcome.body_0.items_0.columns_1.items_0.text)",
                  "size": "Large",
                  "weight": "Bolder",
                  "color": "Accent"
                },
                {
                  "type": "TextBlock",
                  "text": "$t(quickstart_app.welcome.body_0.items_0.columns_1.items_1.text)",
                  "spacing": "None",
                  "isSubtle": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "$t(quickstart_app.welcome.body_1.text)",
      "wrap": true,
      "spacing": "Medium"
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "$t(quickstart_app.welcome.body_2.facts_0_title)",
          "value": "$t(quickstart_app.welcome.body_2.facts_0_value)"
        },
        {
          "title": "$t(quickstart_app.welcome.body_2.facts_1_title)",
          "value": "$t(quickstart_app.welcome.body_2.facts_1_value)"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "$t(quickstart_app.welcome.body_3.text)",
      "wrap": true,
      "spacing": "Medium",
      "isSubtle": true
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "$t(quickstart_app.welcome.actions_0.title)",
      "data": {
        "action": "create_ticket"
      }
    }
  ]
}
