{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "greentic": {
    "cardId": "ticket_resolved",
    "flow": "on_event"
  },
  "body": [
    {
      "type": "Container",
      "style": "good",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$t(quickstart_app.ticket_resolved.body_0.items_0.columns_0.items_0.text)",
                  "size": "ExtraLarge"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "$t(quickstart_app.ticket_resolved.body_0.items_0.columns_1.items_0.text)",
                  "size": "Large",
                  "weight": "Bolder",
                  "color": "Good"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "$t(quickstart_app.ticket_resolved.body_1.facts_0_title)",
          "value": "{{input.event.payload.ticket_id}}"
        },
        {
          "title": "$t(quickstart_app.ticket_resolved.body_1.facts_1_title)",
          "value": "{{input.event.payload.issue}}"
        },
        {
          "title": "$t(quickstart_app.ticket_resolved.body_1.facts_2_title)",
          "value": "$t(quickstart_app.ticket_resolved.body_1.facts_2_value)"
        },
        {
          "title": "$t(quickstart_app.ticket_resolved.body_1.facts_3_title)",
          "value": "{{input.event.payload.resolved_by}}"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "$t(quickstart_app.ticket_resolved.body_2.items_0.text)",
          "weight": "Bolder",
          "color": "Accent"
        },
        {
          "type": "TextBlock",
          "text": "{{input.event.payload.resolution}}",
          "wrap": true
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "$t(quickstart_app.ticket_resolved.body_3.text)",
      "wrap": true,
      "spacing": "Medium",
      "horizontalAlignment": "Center",
      "isSubtle": true
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "$t(quickstart_app.ticket_resolved.actions_0.title)",
      "data": {
        "action": "feedback",
        "ticket_id": "{{input.event.payload.ticket_id}}"
      }
    },
    {
      "type": "Action.Submit",
      "title": "$t(quickstart_app.ticket_resolved.actions_1.title)",
      "data": {
        "action": "reopen",
        "ticket_id": "{{input.event.payload.ticket_id}}"
      }
    }
  ]
}
