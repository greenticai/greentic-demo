{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.6",
  "body": [
    {
      "type": "TextBlock",
      "text": "{{i18n:card.research_plan.body_0.text}}",
      "weight": "Bolder",
      "size": "Large",
      "color": "Accent"
    },
    {
      "type": "TextBlock",
      "text": "{{i18n:card.research_plan.body_1.text}}",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "Container",
      "id": "generatingResearchPlanText",
      "isVisible": "${generatingVisible}",
      "items": [
        {
          "type": "TextBlock",
          "text": "{{i18n:card.research_plan.body_2_items_0.text}}",
          "wrap": true,
          "isSubtle": true
        }
      ]
    },
    {
      "type": "Container",
      "id": "researchPlanContainer",
      "isVisible": "${researchPlanVisible}",
      "items": [
        {
          "type": "TextBlock",
          "text": "${planner_output}",
          "wrap": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "{{i18n:card.research_plan.actions_0.title}}",
      "style": "positive",
      "data": {
        "action": "start_research_analysis",
        "user_question": "${user_question}",
        "planner_output": "${planner_output}"
      }
    },
    {
      "type": "Action.Submit",
      "title": "{{i18n:card.research_plan.actions_1.title}}",
      "data": {
        "routeToCardId": "main_menu"
      }
    }
  ]
}
