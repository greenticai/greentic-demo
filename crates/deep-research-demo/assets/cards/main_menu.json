{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.6",
  "speak": "{{i18n:card.main_menu.speak}}",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "verticalContentAlignment": "Center",
          "items": [
            {
              "type": "Image",
              "url": "https://img.icons8.com/?size=100&id=WDI63NQbh3cO&format=png&color=000000",
              "altText": "{{i18n:card.main_menu.body_0_columns_0_items_0.altText}}",
              "size": "Medium"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "{{i18n:card.main_menu.body_0_columns_1_items_0.text}}",
              "weight": "Bolder",
              "size": "ExtraLarge",
              "color": "Accent"
            },
            {
              "type": "TextBlock",
              "text": "{{i18n:card.main_menu.body_0_columns_1_items_1.text}}",
              "wrap": true,
              "isSubtle": true,
              "spacing": "None"
            }
          ]
        }
      ]
    },
    {
      "type": "Input.Text",
      "id": "user_question",
      "label": "{{i18n:card.main_menu.body_1.label}}",
      "placeholder": "{{i18n:card.main_menu.body_1.placeholder}}",
      "isMultiline": true,
      "isRequired": true,
      "errorMessage": "{{i18n:card.main_menu.body_1.errorMessage}}"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "{{i18n:card.main_menu.actions_0.title}}",
      "data": {
        "action": "single_shot"
      }
    },
    {
      "type": "Action.Submit",
      "title": "{{i18n:card.main_menu.actions_1.title}}",
      "style": "positive",
      "data": {
        "action": "agentic"
      }
    }
  ]
}
