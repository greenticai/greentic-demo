{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.6",
  "body": [
    {
      "type": "TextBlock",
      "text": "{{i18n:card.final_report.body_0.text}}",
      "weight": "Bolder",
      "size": "Large",
      "color": "Accent"
    },
    {
      "type": "TextBlock",
      "text": "{{i18n:card.final_report.body_1.text}}",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "Container",
      "id": "processingText",
      "isVisible": "${processingVisible}",
      "items": [
        {
          "type": "TextBlock",
          "text": "{{i18n:card.final_report.body_2_items_0.text}}",
          "wrap": true,
          "isSubtle": true
        }
      ]
    },
    {
      "type": "Container",
      "id": "final_report_container",
      "isVisible": "${finalReportVisible}",
      "items": [
        {
          "type": "TextBlock",
          "id": "report_output",
          "text": "${report_output}",
          "wrap": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "{{i18n:card.final_report.actions_0.title}}",
      "data": {
        "routeToCardId": "main_menu"
      }
    }
  ]
}
