{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Initech Platform Upgrade"
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Amount",
          "value": "$120,000"
        },
        {
          "title": "Stage",
          "value": "Proposal"
        },
        {
          "title": "Close Date",
          "value": "2026-05-31"
        },
        {
          "title": "Probability",
          "value": "60%"
        },
        {
          "title": "Owner",
          "value": "Maarten Ectors"
        },
        {
          "title": "Last Activity",
          "value": "2026-04-21 — Demo call (45 min)"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Notes"
        },
        {
          "type": "TextBlock",
          "wrap": true,
          "text": "Customer is evaluating against two other vendors. Pricing review scheduled for next week. Champion: VP Engineering. Budget approved Q2.",
          "isSubtle": true
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Update Stage"
        },
        {
          "type": "Input.ChoiceSet",
          "id": "new_stage",
          "style": "compact",
          "value": "Proposal",
          "choices": [
            { "title": "Prospecting", "value": "Prospecting" },
            { "title": "Qualification", "value": "Qualification" },
            { "title": "Needs Analysis", "value": "Needs Analysis" },
            { "title": "Value Proposition", "value": "Value Proposition" },
            { "title": "Proposal/Price Quote", "value": "Proposal" },
            { "title": "Negotiation/Review", "value": "Negotiation" },
            { "title": "Closed Won", "value": "Closed Won" },
            { "title": "Closed Lost", "value": "Closed Lost" }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Update Amount"
        },
        {
          "type": "Input.Number",
          "id": "new_amount",
          "placeholder": "Enter new amount",
          "value": "120000"
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Add Note"
        },
        {
          "type": "Input.Text",
          "id": "note_text",
          "placeholder": "Type a note...",
          "isMultiline": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Update Stage",
      "style": "positive",
      "data": {
        "action_id": "update_stage",
        "opportunity_id": "0061x000ABC003"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Update Amount",
      "data": {
        "action_id": "update_amount",
        "opportunity_id": "0061x000ABC003"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Add Note",
      "data": {
        "action_id": "add_note",
        "opportunity_id": "0061x000ABC003"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Schedule Meeting",
      "data": {
        "action_id": "schedule_meeting",
        "opportunity_id": "0061x000ABC003",
        "routeToCardId": "meeting_card"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Back to Pipeline",
      "data": {
        "action_id": "back",
        "routeToCardId": "pipeline_card"
      }
    }
  ]
}
