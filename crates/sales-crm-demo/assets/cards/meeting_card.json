{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Schedule Meeting"
    },
    {
      "type": "TextBlock",
      "text": "Fill in the meeting details below.",
      "isSubtle": true,
      "wrap": true
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "Input.Text",
          "id": "meeting_subject",
          "label": "Meeting Subject",
          "placeholder": "Discovery call with {{prefill_contact}}",
          "isRequired": true,
          "errorMessage": "Subject is required"
        },
        {
          "type": "Input.Text",
          "id": "contact_id",
          "label": "Contact / Lead Name",
          "placeholder": "Search by name...",
          "value": "{{prefill_contact}}"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Date & Time"
        },
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "Input.Date",
                  "id": "meeting_date",
                  "label": "Date",
                  "isRequired": true,
                  "errorMessage": "Date is required"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "Input.Time",
                  "id": "meeting_time",
                  "label": "Time",
                  "isRequired": true,
                  "errorMessage": "Time is required"
                }
              ]
            }
          ]
        },
        {
          "type": "Input.ChoiceSet",
          "id": "duration",
          "label": "Duration",
          "style": "compact",
          "value": "30",
          "choices": [
            { "title": "15 minutes", "value": "15" },
            { "title": "30 minutes", "value": "30" },
            { "title": "45 minutes", "value": "45" },
            { "title": "1 hour", "value": "60" },
            { "title": "1.5 hours", "value": "90" },
            { "title": "2 hours", "value": "120" }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "Input.ChoiceSet",
          "id": "meeting_type",
          "label": "Meeting Type",
          "style": "compact",
          "value": "call",
          "choices": [
            { "title": "Phone Call", "value": "call" },
            { "title": "Video Conference", "value": "video" },
            { "title": "In-Person", "value": "in_person" },
            { "title": "Demo / Presentation", "value": "demo" },
            { "title": "Lunch Meeting", "value": "lunch" }
          ]
        },
        {
          "type": "Input.Text",
          "id": "meeting_notes",
          "label": "Notes / Agenda",
          "placeholder": "Agenda items, talking points, or preparation notes...",
          "isMultiline": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Schedule Meeting",
      "style": "positive",
      "data": {
        "action_id": "schedule_meeting"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Skip",
      "data": {
        "action_id": "skip"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Back",
      "data": {
        "action_id": "back"
      }
    }
  ]
}
