{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "Container",
      "items": [
        {
          "type": "Image",
          "url": "https://upload.wikimedia.org/wikipedia/commons/f/f9/Salesforce.com_logo.svg",
          "size": "Medium",
          "horizontalAlignment": "Center"
        },
        {
          "type": "TextBlock",
          "size": "Large",
          "weight": "Bolder",
          "text": "Connect to Salesforce",
          "horizontalAlignment": "Center"
        }
      ]
    },
    {
      "type": "TextBlock",
      "wrap": true,
      "text": "This app requires access to your Salesforce account to manage leads, opportunities, and schedule meetings.",
      "horizontalAlignment": "Center"
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Provider",
          "value": "{{provider}}"
        },
        {
          "title": "Permissions",
          "value": "api, refresh_token"
        }
      ]
    },
    {
      "type": "TextBlock",
      "wrap": true,
      "isSubtle": true,
      "text": "You will be redirected to Salesforce to authorize this application. Your credentials are never stored by this app.",
      "size": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Connect to Salesforce",
      "style": "positive",
      "data": {
        "action_id": "connect_salesforce"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Cancel",
      "style": "default",
      "data": {
        "action_id": "cancel"
      }
    }
  ]
}
