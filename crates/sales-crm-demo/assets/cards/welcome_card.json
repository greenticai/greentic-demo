{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "Container",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://upload.wikimedia.org/wikipedia/commons/f/f9/Salesforce.com_logo.svg",
                  "size": "Small"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "size": "Large",
                  "weight": "Bolder",
                  "text": "Sales CRM Assistant"
                },
                {
                  "type": "TextBlock",
                  "text": "Welcome, {{username}}!",
                  "isSubtle": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "wrap": true,
      "text": "What would you like to do?"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "New Lead",
      "style": "positive",
      "data": {
        "action_id": "new_lead",
        "routeToCardId": "lead_form_card"
      }
    },
    {
      "type": "Action.Submit",
      "title": "View Pipeline",
      "data": {
        "action_id": "view_pipeline",
        "routeToCardId": "pipeline_card"
      }
    },
    {
      "type": "Action.Submit",
      "title": "My Deals",
      "data": {
        "action_id": "my_deals",
        "routeToCardId": "deal_detail_card"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Schedule Meeting",
      "data": {
        "action_id": "schedule_meeting",
        "routeToCardId": "meeting_card"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Disconnect",
      "style": "destructive",
      "data": {
        "action_id": "disconnect"
      }
    }
  ]
}