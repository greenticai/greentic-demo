{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Sales Pipeline"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Total Pipeline Value",
              "isSubtle": true,
              "size": "Small"
            },
            {
              "type": "TextBlock",
              "text": "${{total_value}}",
              "weight": "Bolder",
              "size": "Medium"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Active Deals",
              "isSubtle": true,
              "size": "Small"
            },
            {
              "type": "TextBlock",
              "text": "{{deal_count}}",
              "weight": "Bolder",
              "size": "Medium"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "$data": "{{stages}}",
          "type": "Container",
          "spacing": "Medium",
          "items": [
            {
              "type": "TextBlock",
              "weight": "Bolder",
              "text": "{{stage_name}}",
              "color": "Accent"
            },
            {
              "type": "ColumnSet",
              "columns": [
                {
                  "type": "Column",
                  "width": "stretch",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "{{count}} deals",
                      "isSubtle": true,
                      "size": "Small"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "auto",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "${{stage_value}}",
                      "isSubtle": true,
                      "size": "Small"
                    }
                  ]
                }
              ]
            },
            {
              "type": "Container",
              "items": [
                {
                  "$data": "{{deals}}",
                  "type": "Container",
                  "style": "emphasis",
                  "spacing": "Small",
                  "items": [
                    {
                      "type": "ColumnSet",
                      "columns": [
                        {
                          "type": "Column",
                          "width": "stretch",
                          "items": [
                            {
                              "type": "TextBlock",
                              "weight": "Bolder",
                              "text": "{{name}}",
                              "size": "Small"
                            },
                            {
                              "type": "TextBlock",
                              "text": "${{amount}} | {{probability}}% | Close: {{close_date}}",
                              "isSubtle": true,
                              "size": "Small",
                              "wrap": true
                            }
                          ]
                        }
                      ],
                      "selectAction": {
                        "type": "Action.Submit",
                        "data": {
                          "action_id": "view_deal",
                          "opportunity_id": "{{id}}"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Refresh",
      "data": {
        "action_id": "refresh"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Back",
      "data": {
        "action_id": "back"
      }
    }
  ]
}
