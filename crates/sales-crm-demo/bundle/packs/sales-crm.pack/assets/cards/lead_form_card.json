{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "New Lead"
    },
    {
      "type": "TextBlock",
      "text": "Fill in the lead details below. Fields marked with * are required.",
      "isSubtle": true,
      "wrap": true
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Company Information"
        },
        {
          "type": "Input.Text",
          "id": "company",
          "label": "Company Name *",
          "placeholder": "Acme Corporation",
          "isRequired": true,
          "errorMessage": "Company name is required"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Contact Details"
        },
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "Input.Text",
                  "id": "first_name",
                  "label": "First Name",
                  "placeholder": "Jane"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "Input.Text",
                  "id": "last_name",
                  "label": "Last Name *",
                  "placeholder": "Smith",
                  "isRequired": true,
                  "errorMessage": "Last name is required"
                }
              ]
            }
          ]
        },
        {
          "type": "Input.Text",
          "id": "email",
          "label": "Email",
          "placeholder": "jane.smith@acme.com",
          "style": "Email"
        },
        {
          "type": "Input.Text",
          "id": "phone",
          "label": "Phone",
          "placeholder": "+1 (555) 123-4567",
          "style": "Tel"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Qualification Criteria"
        },
        {
          "type": "Input.ChoiceSet",
          "id": "budget_range",
          "label": "Budget Range",
          "style": "compact",
          "value": "unknown",
          "choices": [
            { "title": "Unknown", "value": "unknown" },
            { "title": "Under $10K", "value": "under_10k" },
            { "title": "$10K - $50K", "value": "10k_50k" },
            { "title": "$50K - $100K", "value": "50k_100k" },
            { "title": "$100K - $500K", "value": "100k_500k" },
            { "title": "Over $500K", "value": "over_500k" }
          ]
        },
        {
          "type": "Input.ChoiceSet",
          "id": "timeline",
          "label": "Purchase Timeline",
          "style": "compact",
          "value": "unknown",
          "choices": [
            { "title": "Unknown", "value": "unknown" },
            { "title": "Immediate (< 1 month)", "value": "immediate" },
            { "title": "Short-term (1-3 months)", "value": "short_term" },
            { "title": "Mid-term (3-6 months)", "value": "mid_term" },
            { "title": "Long-term (6-12 months)", "value": "long_term" },
            { "title": "Over 12 months", "value": "over_12_months" }
          ]
        },
        {
          "type": "Input.ChoiceSet",
          "id": "lead_source",
          "label": "Lead Source",
          "style": "compact",
          "value": "other",
          "choices": [
            { "title": "Web", "value": "web" },
            { "title": "Phone Inquiry", "value": "phone" },
            { "title": "Partner Referral", "value": "partner" },
            { "title": "Trade Show", "value": "trade_show" },
            { "title": "Email Campaign", "value": "email_campaign" },
            { "title": "Social Media", "value": "social_media" },
            { "title": "Other", "value": "other" }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Create & Qualify Lead",
      "style": "positive",
      "data": {
        "action_id": "submit_lead"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Back",
      "data": {
        "action_id": "back"
      }
    }
  ]
}
