{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Create Reorder Request"
    },
    {
      "type": "TextBlock",
      "text": "Fill in the details below to create a purchase order.",
      "isSubtle": true,
      "wrap": true
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "Product Information",
          "weight": "Bolder",
          "spacing": "Small"
        },
        {
          "type": "Input.Text",
          "id": "product_sku",
          "label": "Product SKU",
          "placeholder": "Enter SKU (e.g., SKU-RAW-001)",
          "value": "{{prefill_sku}}",
          "isRequired": true,
          "errorMessage": "Product SKU is required"
        },
        {
          "type": "FactSet",
          "spacing": "Small",
          "facts": [
            { "title": "Product", "value": "{{prefill_product_name}}" },
            { "title": "Current Stock", "value": "{{prefill_current_stock}} units" },
            { "title": "Minimum Level", "value": "{{prefill_min_level}} units" }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Order Details",
          "weight": "Bolder"
        },
        {
          "type": "Input.Number",
          "id": "quantity",
          "label": "Quantity to Order",
          "placeholder": "Enter quantity",
          "min": 1,
          "max": 100000,
          "value": "{{suggested_quantity}}",
          "isRequired": true,
          "errorMessage": "Quantity must be greater than 0"
        },
        {
          "type": "Input.ChoiceSet",
          "id": "supplier_id",
          "label": "Supplier",
          "placeholder": "Select supplier",
          "value": "{{preferred_supplier}}",
          "isRequired": true,
          "errorMessage": "Please select a supplier",
          "choices": [
            { "title": "Acme Industrial Supply", "value": "SUP-001" },
            { "title": "Global Materials Co.", "value": "SUP-002" },
            { "title": "Pacific Components Ltd.", "value": "SUP-003" },
            { "title": "EuroTech Parts GmbH", "value": "SUP-004" },
            { "title": "Atlas Raw Materials Inc.", "value": "SUP-005" }
          ]
        },
        {
          "type": "Input.ChoiceSet",
          "id": "urgency",
          "label": "Urgency Level",
          "value": "normal",
          "choices": [
            { "title": "Normal (Standard lead time)", "value": "normal" },
            { "title": "Urgent (Expedited shipping)", "value": "urgent" },
            { "title": "Critical (Emergency order)", "value": "critical" }
          ]
        },
        {
          "type": "Input.Date",
          "id": "delivery_date",
          "label": "Requested Delivery Date"
        },
        {
          "type": "Input.Text",
          "id": "notes",
          "label": "Notes",
          "placeholder": "Additional notes or special instructions...",
          "isMultiline": true
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Currency: {{currency}}",
                  "isSubtle": true,
                  "size": "Small"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Standard Lead Time: {{lead_days}} days",
                  "isSubtle": true,
                  "size": "Small",
                  "horizontalAlignment": "Right"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Submit Reorder Request",
      "style": "positive",
      "data": {
        "action_id": "submit_reorder"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Back",
      "data": {
        "action_id": "back"
      }
    }
  ]
}
