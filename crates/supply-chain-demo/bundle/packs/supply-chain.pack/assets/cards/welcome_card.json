{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://cdn-icons-png.flaticon.com/512/2897/2897785.png",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "TextBlock",
                  "size": "Large",
                  "weight": "Bolder",
                  "text": "Supply Chain Dashboard"
                },
                {
                  "type": "TextBlock",
                  "text": "Inventory & Order Management",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Key Metrics",
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "1",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Total SKUs",
                  "isSubtle": true,
                  "size": "Small",
                  "horizontalAlignment": "Center"
                },
                {
                  "type": "TextBlock",
                  "text": "{{total_skus}}",
                  "weight": "Bolder",
                  "size": "ExtraLarge",
                  "horizontalAlignment": "Center",
                  "color": "Accent"
                }
              ]
            },
            {
              "type": "Column",
              "width": "1",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Low Stock",
                  "isSubtle": true,
                  "size": "Small",
                  "horizontalAlignment": "Center"
                },
                {
                  "type": "TextBlock",
                  "text": "{{low_stock_count}}",
                  "weight": "Bolder",
                  "size": "ExtraLarge",
                  "horizontalAlignment": "Center",
                  "color": "Attention"
                }
              ]
            },
            {
              "type": "Column",
              "width": "1",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Pending Orders",
                  "isSubtle": true,
                  "size": "Small",
                  "horizontalAlignment": "Center"
                },
                {
                  "type": "TextBlock",
                  "text": "{{pending_orders}}",
                  "weight": "Bolder",
                  "size": "ExtraLarge",
                  "horizontalAlignment": "Center",
                  "color": "Warning"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "What would you like to do?",
          "wrap": true,
          "spacing": "Small"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Check Stock",
      "style": "positive",
      "data": {
        "action_id": "check_stock"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Track Orders",
      "data": {
        "action_id": "track_orders"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Low Stock Alerts",
      "style": "destructive",
      "data": {
        "action_id": "low_stock_alerts"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Create Reorder",
      "data": {
        "action_id": "create_reorder"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Supplier Directory",
      "data": {
        "action_id": "supplier_directory"
      }
    }
  ]
}
