{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Inventory Stock Status"
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "Input.Text",
                  "id": "search_query",
                  "placeholder": "Search by SKU, product name, or category...",
                  "value": "{{search_query}}"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.Submit",
                      "title": "Search",
                      "style": "positive",
                      "data": {
                        "action_id": "search_stock"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "1",
              "items": [
                {
                  "type": "Input.ChoiceSet",
                  "id": "category_filter",
                  "placeholder": "Category",
                  "choices": [
                    { "title": "All Categories", "value": "" },
                    { "title": "Raw Materials", "value": "raw_materials" },
                    { "title": "Components", "value": "components" },
                    { "title": "Finished Goods", "value": "finished_goods" },
                    { "title": "Packaging", "value": "packaging" },
                    { "title": "Consumables", "value": "consumables" }
                  ]
                }
              ]
            },
            {
              "type": "Column",
              "width": "1",
              "items": [
                {
                  "type": "Input.ChoiceSet",
                  "id": "warehouse_filter",
                  "placeholder": "Warehouse",
                  "choices": [
                    { "title": "All Warehouses", "value": "" },
                    { "title": "WH-001 (Main)", "value": "WH-001" },
                    { "title": "WH-002 (East)", "value": "WH-002" },
                    { "title": "WH-003 (West)", "value": "WH-003" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "{{total_results}} items found",
      "isSubtle": true,
      "spacing": "Small"
    },
    {
      "type": "Container",
      "items": [
        {
          "type": "ColumnSet",
          "style": "emphasis",
          "columns": [
            { "type": "Column", "width": "1", "items": [{ "type": "TextBlock", "text": "SKU", "weight": "Bolder", "size": "Small" }] },
            { "type": "Column", "width": "2", "items": [{ "type": "TextBlock", "text": "Product", "weight": "Bolder", "size": "Small" }] },
            { "type": "Column", "width": "1", "items": [{ "type": "TextBlock", "text": "Warehouse", "weight": "Bolder", "size": "Small" }] },
            { "type": "Column", "width": "1", "items": [{ "type": "TextBlock", "text": "Qty", "weight": "Bolder", "size": "Small", "horizontalAlignment": "Right" }] },
            { "type": "Column", "width": "1", "items": [{ "type": "TextBlock", "text": "Min Level", "weight": "Bolder", "size": "Small", "horizontalAlignment": "Right" }] },
            { "type": "Column", "width": "1", "items": [{ "type": "TextBlock", "text": "Status", "weight": "Bolder", "size": "Small", "horizontalAlignment": "Center" }] }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "$data": "{{items}}",
          "type": "Container",
          "spacing": "Small",
          "items": [
            {
              "type": "ColumnSet",
              "columns": [
                {
                  "type": "Column",
                  "width": "1",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "{{sku}}",
                      "size": "Small",
                      "fontType": "Monospace"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "2",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "{{product_name}}",
                      "size": "Small",
                      "wrap": true
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "1",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "{{warehouse}}",
                      "size": "Small"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "1",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "{{quantity}}",
                      "size": "Small",
                      "horizontalAlignment": "Right"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "1",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "{{min_level}}",
                      "size": "Small",
                      "horizontalAlignment": "Right"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "1",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "{{status_indicator}}",
                      "size": "Small",
                      "horizontalAlignment": "Center",
                      "color": "{{status_color}}"
                    }
                  ]
                }
              ],
              "selectAction": {
                "type": "Action.Submit",
                "data": {
                  "action_id": "view_item",
                  "sku": "{{sku}}"
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "View Low Stock Only",
      "data": {
        "action_id": "view_all_low_stock"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Back",
      "data": {
        "action_id": "back"
      }
    }
  ]
}
