{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "Container",
      "style": "attention",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://cdn-icons-png.flaticon.com/512/1680/1680012.png",
                  "size": "Small"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "TextBlock",
                  "size": "Large",
                  "weight": "Bolder",
                  "text": "Low Stock Alerts",
                  "color": "Attention"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "{{total_alerts}} items",
                  "weight": "Bolder",
                  "color": "Attention"
                }
              ]
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "The following items are below the minimum threshold of {{threshold}} units.",
          "wrap": true,
          "isSubtle": true,
          "size": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "$data": "{{items}}",
          "type": "Container",
          "style": "emphasis",
          "spacing": "Small",
          "items": [
            {
              "type": "ColumnSet",
              "columns": [
                {
                  "type": "Column",
                  "width": "3",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "{{product_name}}",
                      "weight": "Bolder"
                    },
                    {
                      "type": "TextBlock",
                      "text": "SKU: {{sku}} | Warehouse: {{warehouse}}",
                      "isSubtle": true,
                      "size": "Small",
                      "spacing": "None"
                    },
                    {
                      "type": "TextBlock",
                      "text": "Category: {{category}}",
                      "isSubtle": true,
                      "size": "Small",
                      "spacing": "None"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "2",
                  "items": [
                    {
                      "type": "ColumnSet",
                      "columns": [
                        {
                          "type": "Column",
                          "width": "1",
                          "items": [
                            {
                              "type": "TextBlock",
                              "text": "Current",
                              "size": "Small",
                              "isSubtle": true,
                              "horizontalAlignment": "Center"
                            },
                            {
                              "type": "TextBlock",
                              "text": "{{current_quantity}}",
                              "weight": "Bolder",
                              "color": "Attention",
                              "horizontalAlignment": "Center"
                            }
                          ]
                        },
                        {
                          "type": "Column",
                          "width": "1",
                          "items": [
                            {
                              "type": "TextBlock",
                              "text": "Min",
                              "size": "Small",
                              "isSubtle": true,
                              "horizontalAlignment": "Center"
                            },
                            {
                              "type": "TextBlock",
                              "text": "{{min_threshold}}",
                              "weight": "Bolder",
                              "horizontalAlignment": "Center"
                            }
                          ]
                        },
                        {
                          "type": "Column",
                          "width": "1",
                          "items": [
                            {
                              "type": "TextBlock",
                              "text": "Reorder",
                              "size": "Small",
                              "isSubtle": true,
                              "horizontalAlignment": "Center"
                            },
                            {
                              "type": "TextBlock",
                              "text": "{{suggested_reorder_qty}}",
                              "weight": "Bolder",
                              "color": "Good",
                              "horizontalAlignment": "Center"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "ActionSet",
              "actions": [
                {
                  "type": "Action.Submit",
                  "title": "Quick Reorder",
                  "style": "positive",
                  "data": {
                    "action_id": "quick_reorder",
                    "sku": "{{sku}}",
                    "suggested_qty": "{{suggested_reorder_qty}}",
                    "supplier_id": "{{preferred_supplier_id}}"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Reorder All Low Stock",
      "style": "positive",
      "data": {
        "action_id": "reorder_all"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Back",
      "data": {
        "action_id": "back"
      }
    }
  ]
}
