{
  "type": "AdaptiveCard",
  "version": "1.6",
  "body": [
    {
      "type": "TextBlock",
      "text": "{{#if ok}}Incident created{{else}}Incident creation failed{{/if}}",
      "size": "Large",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "Status: {{ status }}",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "{{#if incident_id}}Incident ID: {{ incident_id }}{{else}}No incident ID returned{{/if}}",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Response: {{ response }}",
      "wrap": true,
      "spacing": "Medium"
    }
  ]
}
