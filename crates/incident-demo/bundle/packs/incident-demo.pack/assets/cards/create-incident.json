{
  "type": "AdaptiveCard",
  "version": "1.6",
  "body": [
    {
      "type": "TextBlock",
      "text": "Create incident",
      "size": "Large",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "This will create a new incident and alert the current on-call person.",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "Requester", "value": "{{ requester_email }}" },
        { "title": "Name", "value": "{{ name }}" },
        { "title": "Summary", "value": "{{ summary }}" },
        { "title": "Call", "value": "{{ call }}" },
        { "title": "SMS", "value": "{{ sms }}" },
        { "title": "Email", "value": "{{ email }}" },
        { "title": "Critical", "value": "{{ critical_alert }}" },
        { "title": "Team wait", "value": "{{ team_wait }}" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "{{ description }}",
      "wrap": true
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "Create incident",
      "verb": "submit",
      "data": {
        "route": "submit",
        "requester_email": "{{ requester_email }}",
        "name": "{{ name }}",
        "summary": "{{ summary }}",
        "description": "{{ description }}",
        "call": true,
        "sms": true,
        "email": true,
        "critical_alert": true,
        "team_wait": 300
      }
    }
  ]
}
