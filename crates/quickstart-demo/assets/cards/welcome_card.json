{
  "type": "AdaptiveCard",
  "version": "1.6",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "👋",
                  "size": "ExtraLarge"
                }
              ],
              "verticalContentAlignment": "Center"
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "{{ greeting }}",
                  "size": "Large",
                  "weight": "Bolder",
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "I'm your AI assistant powered by Greentic. I can help you learn about the platform, guide you through setup, or answer your questions.",
                  "wrap": true,
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "Small"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "What would you like to explore?",
      "weight": "Bolder",
      "spacing": "Large"
    },
    {
      "type": "ColumnSet",
      "spacing": "Medium",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "ActionSet",
              "actions": [
                {
                  "type": "Action.Execute",
                  "title": "🏠 About Greentic",
                  "verb": "about"
                },
                {
                  "type": "Action.Execute",
                  "title": "🚀 Getting Started",
                  "verb": "getting_started"
                }
              ]
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "ActionSet",
              "actions": [
                {
                  "type": "Action.Execute",
                  "title": "💡 What Can I Do?",
                  "verb": "capabilities"
                },
                {
                  "type": "Action.Execute",
                  "title": "🔧 How It Works",
                  "verb": "architecture"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
