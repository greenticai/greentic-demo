{
  "type": "AdaptiveCard",
  "version": "1.6",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "body": [
    {
      "type": "TextBlock",
      "text": "💡 What Can I Do?",
      "size": "Large",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "Greentic digital workers can automate conversations and tasks across multiple channels:",
      "wrap": true,
      "spacing": "Medium"
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "**💬 Multi-Channel Messaging**",
          "spacing": "Small"
        },
        {
          "type": "TextBlock",
          "text": "Slack, Microsoft Teams, Telegram, WhatsApp, Webex, WebChat, Email — one flow, all channels.",
          "wrap": true,
          "isSubtle": true,
          "size": "Small"
        },
        {
          "type": "TextBlock",
          "text": "**🎴 Rich Adaptive Cards**",
          "spacing": "Medium"
        },
        {
          "type": "TextBlock",
          "text": "Interactive forms, buttons, images, and data displays that work across platforms.",
          "wrap": true,
          "isSubtle": true,
          "size": "Small"
        },
        {
          "type": "TextBlock",
          "text": "**⚡ Event-Driven Automation**",
          "spacing": "Medium"
        },
        {
          "type": "TextBlock",
          "text": "Webhooks, timers, email triggers, SMS — react to events from any source.",
          "wrap": true,
          "isSubtle": true,
          "size": "Small"
        },
        {
          "type": "TextBlock",
          "text": "**🔐 OAuth & MCP Integration**",
          "spacing": "Medium"
        },
        {
          "type": "TextBlock",
          "text": "Connect to GitHub, Google, Microsoft APIs securely. Use MCP tools for AI-powered actions.",
          "wrap": true,
          "isSubtle": true,
          "size": "Small"
        },
        {
          "type": "TextBlock",
          "text": "**🌍 Multi-Language & Multi-Tenant**",
          "spacing": "Medium"
        },
        {
          "type": "TextBlock",
          "text": "Built-in i18n (50+ languages), per-tenant isolation, custom branding per team.",
          "wrap": true,
          "isSubtle": true,
          "size": "Small"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "📚 Browse Components",
      "url": "https://docs.greentic.ai/components/fast2flow/"
    },
    {
      "type": "Action.Execute",
      "title": "← Back to menu",
      "verb": "back"
    }
  ]
}
