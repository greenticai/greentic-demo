{
  "type": "AdaptiveCard",
  "version": "1.6",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "body": [
    {
      "type": "TextBlock",
      "text": "🚀 Getting Started",
      "size": "Large",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "Get up and running with Greentic in 4 simple steps:",
      "wrap": true,
      "spacing": "Medium"
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [{ "type": "TextBlock", "text": "**1**", "color": "Accent" }]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                { "type": "TextBlock", "text": "**Install the CLI**", "wrap": true },
                { "type": "TextBlock", "text": "`cargo binstall greentic`", "wrap": true, "isSubtle": true, "size": "Small" }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [{ "type": "TextBlock", "text": "**2**", "color": "Accent" }]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                { "type": "TextBlock", "text": "**Create a bundle**", "wrap": true },
                { "type": "TextBlock", "text": "`gtc wizard` — interactive setup for your first digital worker", "wrap": true, "isSubtle": true, "size": "Small" }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [{ "type": "TextBlock", "text": "**3**", "color": "Accent" }]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                { "type": "TextBlock", "text": "**Configure providers**", "wrap": true },
                { "type": "TextBlock", "text": "`gtc setup ./my-bundle` — connect Slack, Teams, or WebChat", "wrap": true, "isSubtle": true, "size": "Small" }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [{ "type": "TextBlock", "text": "**4**", "color": "Accent" }]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                { "type": "TextBlock", "text": "**Start & chat!**", "wrap": true },
                { "type": "TextBlock", "text": "`gtc start ./my-bundle` — your digital worker is live", "wrap": true, "isSubtle": true, "size": "Small" }
              ]
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "📖 Full Guide",
      "url": "https://docs.greentic.ai/getting-started/quick-start/"
    },
    {
      "type": "Action.Execute",
      "title": "← Back to menu",
      "verb": "back"
    }
  ]
}
