{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "accent",
      "bleed": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "High-value invoice received",
          "size": "Large",
          "weight": "Bolder",
          "wrap": true,
          "color": "Light"
        },
        {
          "type": "TextBlock",
          "text": "Vertex Industrial Systems invoice INV-78122 is above the director approval threshold.",
          "wrap": true,
          "spacing": "Small",
          "color": "Light"
        }
      ]
    },
    {
      "type": "FactSet",
      "spacing": "Medium",
      "facts": [
        { "title": "Supplier", "value": "Vertex Industrial Systems" },
        { "title": "Invoice", "value": "INV-78122" },
        { "title": "Date", "value": "2026-04-04" },
        { "title": "PO", "value": "PO-77120" },
        { "title": "Currency", "value": "GBP" },
        { "title": "Subtotal", "value": "£18,000.00" },
        { "title": "VAT", "value": "£3,600.00" },
        { "title": "Total", "value": "£21,600.00" },
        { "title": "Confidence", "value": "95%" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "All totals are valid, but the amount requires director-level approval.",
      "wrap": true,
      "spacing": "Medium",
      "isSubtle": true
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Continue to validation",
          "data": { "scenario": "high_value_escalation", "step": "summary", "action": "high_value_validation_passed" }
        },
        {
          "type": "Action.Submit",
          "title": "Back to scenarios",
          "data": { "scenario": "high_value_escalation", "step": "summary", "action": "scenario_selector" }
        }
      ]
    }
  ]
}
