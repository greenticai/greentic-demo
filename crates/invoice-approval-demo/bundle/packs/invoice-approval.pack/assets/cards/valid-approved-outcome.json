{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "good",
      "bleed": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Approved",
          "size": "Large",
          "weight": "Bolder",
          "wrap": true,
          "color": "Light"
        },
        {
          "type": "TextBlock",
          "text": "The invoice has been approved and recorded.",
          "wrap": true,
          "spacing": "Small",
          "color": "Light"
        }
      ]
    },
    {
      "type": "FactSet",
      "spacing": "Medium",
      "facts": [
        { "title": "Status", "value": "Approved" },
        { "title": "Approver", "value": "Maya Chen, Finance Manager" },
        { "title": "Next step", "value": "Queued for the next payment run" }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Review another invoice",
          "data": { "scenario": "valid_invoice", "step": "approved_outcome", "action": "scenario_selector" }
        }
      ]
    }
  ]
}
