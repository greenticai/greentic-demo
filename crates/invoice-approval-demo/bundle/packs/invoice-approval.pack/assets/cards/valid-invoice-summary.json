{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "accent",
      "bleed": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Invoice received",
          "size": "Large",
          "weight": "Bolder",
          "wrap": true,
          "color": "Light"
        },
        {
          "type": "TextBlock",
          "text": "Acme Office Supplies invoice INV-20481 is ready for a quick review.",
          "wrap": true,
          "spacing": "Small",
          "color": "Light"
        }
      ]
    },
    {
      "type": "FactSet",
      "spacing": "Medium",
      "facts": [
        { "title": "Supplier", "value": "Acme Office Supplies" },
        { "title": "Invoice", "value": "INV-20481" },
        { "title": "Date", "value": "2026-04-03" },
        { "title": "PO", "value": "PO-11892" },
        { "title": "Currency", "value": "GBP" },
        { "title": "Subtotal", "value": "£2,400.00" },
        { "title": "VAT", "value": "£480.00" },
        { "title": "Total", "value": "£2,880.00" },
        { "title": "Confidence", "value": "98%" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "The document matches the expected layout and purchase order reference.",
      "wrap": true,
      "spacing": "Medium",
      "isSubtle": true
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Continue to validation",
          "data": { "scenario": "valid_invoice", "step": "summary", "action": "valid_validation_passed" }
        },
        {
          "type": "Action.Submit",
          "title": "Back to scenarios",
          "data": { "scenario": "valid_invoice", "step": "summary", "action": "scenario_selector" }
        }
      ]
    }
  ]
}
