{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Escalate Ticket",
      "color": "Attention"
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "FactSet",
          "facts": [
            {
              "title": "Ticket",
              "value": "{{issue_key}}"
            },
            {
              "title": "Current Priority",
              "value": "{{current_priority}}"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "wrap": true,
      "text": "Escalating this ticket will increase its priority and route it to the next support tier. Please provide the reason and select the new priority level."
    },
    {
      "type": "Input.ChoiceSet",
      "id": "escalation_priority",
      "label": "Escalate To Priority",
      "value": "High",
      "choices": [
        {
          "title": "Highest - Critical, requires immediate response",
          "value": "Highest"
        },
        {
          "title": "High - Major impact, needs urgent attention",
          "value": "High"
        }
      ]
    },
    {
      "type": "Input.ChoiceSet",
      "id": "escalation_tier",
      "label": "Escalation Tier",
      "value": "tier2",
      "choices": [
        {
          "title": "Tier 2 - Senior Support Engineer",
          "value": "tier2"
        },
        {
          "title": "Tier 3 - Subject Matter Expert",
          "value": "tier3"
        },
        {
          "title": "Management - Operations Manager",
          "value": "management"
        }
      ]
    },
    {
      "type": "Input.Text",
      "id": "escalation_reason",
      "label": "Reason for Escalation",
      "placeholder": "Explain why this ticket needs escalation (e.g., SLA breach, customer impact, recurring issue)...",
      "isMultiline": true,
      "isRequired": true,
      "errorMessage": "Please provide a reason for escalation"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "urgency_level",
      "label": "Urgency Level",
      "value": "standard",
      "choices": [
        {
          "title": "Immediate - Needs resolution within 1 hour",
          "value": "immediate"
        },
        {
          "title": "Standard - Needs resolution within 4 hours",
          "value": "standard"
        },
        {
          "title": "Next Business Day - Needs resolution by next business day",
          "value": "next_business_day"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Confirm Escalation",
      "style": "destructive",
      "data": {
        "action_id": "confirm_escalation"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Cancel",
      "style": "default",
      "data": {
        "action_id": "cancel"
      }
    }
  ]
}
