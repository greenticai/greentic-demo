{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "Container",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://cdn.icon-icons.com/icons2/2699/PNG/512/atlassian_jira_logo_icon_170511.png",
                  "size": "Small"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "size": "Large",
                  "weight": "Bolder",
                  "text": "IT Helpdesk"
                },
                {
                  "type": "TextBlock",
                  "text": "Welcome, {{display_name}}!",
                  "isSubtle": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "wrap": true,
      "text": "How can I help you today? Choose an option below:"
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Small",
      "items": [
        {
          "type": "FactSet",
          "facts": [
            {
              "title": "Project",
              "value": "{{project_key}}"
            },
            {
              "title": "Status",
              "value": "Connected to Jira"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Create Ticket",
      "style": "positive",
      "data": {
        "action_id": "create_ticket"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Check Status",
      "data": {
        "action_id": "check_status"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Search KB",
      "data": {
        "action_id": "search_kb"
      }
    },
    {
      "type": "Action.Submit",
      "title": "My Tickets",
      "data": {
        "action_id": "my_tickets"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Disconnect",
      "style": "destructive",
      "data": {
        "action_id": "disconnect"
      }
    }
  ]
}
