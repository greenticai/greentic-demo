{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {"type": "TextBlock", "size": "Large", "weight": "Bolder", "text": "MCP result"},
    {"type": "FactSet", "facts": [
      {"title": "Provider", "value": "{{provider}}"},
      {"title": "City", "value": "{{city}}"}
    ]},
    {"type": "TextBlock", "wrap": true, "fontType": "Monospace", "text": "{{payload}}"}
  ]
}
