{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {"type": "TextBlock", "size": "Large", "weight": "Bolder", "text": "OAuth step"},
    {"type": "TextBlock", "wrap": true, "text": "Provider: {{provider}}"},
    {"type": "TextBlock", "wrap": true, "text": "City: {{city}}"},
    {"type": "TextBlock", "wrap": true, "isSubtle": true, "text": "Token was provided via QA input for this deterministic demo."}
  ],
  "actions": [
    {"type": "Action.Submit", "title": "Continue", "data": {"action_id": "oauth_continue"}}
  ]
}
