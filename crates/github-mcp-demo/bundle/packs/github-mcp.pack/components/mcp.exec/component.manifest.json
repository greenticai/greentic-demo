{
  "id": "mcp.exec",
  "version": "0.1.0",
  "world": "root:component/root",
  "supports": ["messaging"],
  "profiles": {
    "default": "default",
    "supported": ["default"]
  },
  "capabilities": {
    "wasi": {
      "random": false,
      "clocks": false
    },
    "host": {
      "http": { "client": true },
      "secrets": { "required": [{ "key": "github_token", "required": false }] },
      "state": { "read": true, "write": true }
    }
  },
  "artifacts": {
    "component_wasm": "component.wasm"
  }
}
