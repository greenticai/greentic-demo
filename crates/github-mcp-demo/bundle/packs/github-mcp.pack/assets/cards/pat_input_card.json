{
  "type": "AdaptiveCard",
  "version": "1.5",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "body": [
    {
      "type": "TextBlock",
      "text": "Enter Personal Access Token",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Paste your GitHub Personal Access Token below. It needs `repo` scope to access repository data.",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "Input.Text",
      "id": "pat_token",
      "label": "Personal Access Token",
      "placeholder": "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "isRequired": true,
      "style": "Password",
      "errorMessage": "Please enter a valid GitHub PAT."
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Connect",
      "style": "positive",
      "data": { "action_id": "submit_pat" }
    },
    {
      "type": "Action.Submit",
      "title": "Back",
      "data": { "action_id": "go_back" }
    }
  ]
}
