{
  "type": "AdaptiveCard",
  "version": "1.5",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "body": [
    {
      "type": "TextBlock",
      "text": "GitHub Authentication",
      "weight": "Bolder",
      "size": "Large",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Choose how you want to connect to GitHub. You can use OAuth for secure login, or enter a Personal Access Token (PAT) directly.",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "🔐",
              "size": "ExtraLarge"
            }
          ],
          "verticalContentAlignment": "Center"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "OAuth Login",
              "weight": "Bolder",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "Sign in with your GitHub account. Secure and easy.",
              "wrap": true,
              "isSubtle": true,
              "size": "Small"
            }
          ]
        }
      ]
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "🔑",
              "size": "ExtraLarge"
            }
          ],
          "verticalContentAlignment": "Center"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Personal Access Token",
              "weight": "Bolder",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "Paste a GitHub PAT with repo access.",
              "wrap": true,
              "isSubtle": true,
              "size": "Small"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Login with OAuth",
      "style": "positive",
      "url": "oauth://start"
    },
    {
      "type": "Action.Submit",
      "title": "Use PAT instead",
      "data": { "action_id": "use_pat" }
    }
  ]
}
