{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Event Demo"
    },
    {
      "type": "TextBlock",
      "text": "This demo showcases all Greentic event providers working together.",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Available Event Providers"
        },
        {
          "type": "FactSet",
          "facts": [
            { "title": "Webhook", "value": "Receive HTTP POST events" },
            { "title": "Timer", "value": "Cron-scheduled events" },
            { "title": "Email", "value": "SendGrid email events" },
            { "title": "SMS", "value": "Twilio SMS events" }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Send a webhook to test:",
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "curl -X POST {public_url}/events/webhook/demo/alert -H 'Content-Type: application/json' -d '{\"message\": \"Hello!\"}'",
      "fontType": "Monospace",
      "size": "Small",
      "wrap": true
    }
  ]
}
