{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Email Event",
      "color": "Warning"
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "Provider", "value": "SendGrid" },
        { "title": "Event Type", "value": "email" },
        { "title": "Status", "value": "Sent" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "An email event was processed via the SendGrid provider.",
      "wrap": true,
      "isSubtle": true
    }
  ]
}
