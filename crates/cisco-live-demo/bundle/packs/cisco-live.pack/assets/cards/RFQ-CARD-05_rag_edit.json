        },
        {
          "from": "RFQ-CARD-05B_rag_answer",
          "path": "actions/[0]",
          "via": "action.data:toCardId"
        }
      ],
      "incomingResolved": [
        {
          "condition": "explicit:routeToCardId",
          "from": "RFQ-CARD-04_task_detail",
          "path": "body/[6]/selectAction"
        },
        {
          "condition": "explicit:toCardId",
          "from": "RFQ-CARD-05B_rag_answer",
          "path": "actions/[0]"
