id: main
type: messaging
start: main_menu
parameters: {}
tags: []
schema_version: 2
entrypoints: {}
nodes:
  technical_intro:
    routing:
    - to: technical_form
    card:
      call:
        metadata: []
        op: render
        payload:
          card_source: asset
          card_spec:
            asset_path: assets/cards/technical_intro.json
            i18n_bundle_path: assets/i18n
            i18n_inline:
              en:
                card.customer_confirmation.body_0.text: Thank you!
                card.customer_confirmation.body_1.text: Our AI is analyzing your business profile right now
                card.customer_confirmation.body_2.text: We're using ChatGPT to enrich your company profile and suggest tailored AI use cases.
                card.customer_confirmation.body_3.text: A Greentic specialist will reach out within 24 hours with your personalized AI strategy.
                card.customer_form.actions_0.title: Get My AI Strategy
                card.customer_form.actions_1.title: Back
                card.customer_form.body_0.text: Tell us about your business
                card.customer_form.body_1.text: We'll prepare a tailored AI strategy for you
                card.customer_form.body_2.errorMessage: Full Name is required
                card.customer_form.body_2.label: Full Name
                card.customer_form.body_2.placeholder: John Doe
                card.customer_form.body_3.errorMessage: Company Name is required
                card.customer_form.body_3.label: Company Name
                card.customer_form.body_3.placeholder: Acme Corp
                card.customer_form.body_4.label: Website URL
                card.customer_form.body_4.placeholder: https://example.com
                card.customer_form.body_5.errorMessage: Business Email is required
                card.customer_form.body_5.label: Business Email
                card.customer_form.body_5.placeholder: john@acme.com
                card.customer_form.body_6.label: Job Title
                card.customer_form.body_6.placeholder: Head of Operations
                card.customer_form.body_7.label: Current Challenges
                card.customer_form.body_7.placeholder: Describe the processes you'd like to automate...
                card.customer_form.body_8.label: Calendar URL (optional)
                card.customer_form.body_8.placeholder: https://calendly.com/...
                card.customer_intro.actions_0.title: Continue →
                card.customer_intro.actions_1.title: Back
                card.customer_intro.body_0.text: AI-Powered Digital Workers
                card.customer_intro.body_1.text: Transform your business with intelligent automation
                card.customer_intro.body_2.text: Greentic Digital Workers automate repetitive business processes using state-of-the-art AI.
                card.customer_intro.body_3.text: From document processing to customer interactions — our digital workers deliver measurable ROI.
                card.customer_intro.body_4.text: Join leading enterprises that have reduced operational costs by up to 60%.
                card.developer_confirmation.body_0.text: Welcome, developer!
                card.developer_confirmation.body_1.text: You're now part of the Greentic community
                card.developer_confirmation.body_2.text: Check your email for access details and contributor guidelines.
                card.developer_form.actions_0.title: Join Waiting List
                card.developer_form.actions_1.title: Back
                card.developer_form.body_0.text: Join the Developer Community
                card.developer_form.body_1.errorMessage: Full Name is required
                card.developer_form.body_1.label: Full Name
                card.developer_form.body_2.label: GitHub Handle
                card.developer_form.body_2.placeholder: '@username'
                card.developer_form.body_3.errorMessage: Email is required
                card.developer_form.body_3.label: Email
                card.developer_intro.actions_0.title: Continue →
                card.developer_intro.actions_1.title: Back
                card.developer_intro.body_0.text: Build with Greentic
                card.developer_intro.body_1.text: Open-source AI tooling for developers
                card.developer_intro.body_2.text: Explore our open-source repositories and contribute to the ecosystem.
                card.developer_intro.body_3.text: Access comprehensive documentation and API references.
                card.developer_intro.body_4.text: '[GitHub](https://github.com/greenticai)'
                card.developer_intro.body_5.text: '[Documentation](https://docs.greentic.ai)'
                card.explorer_confirmation.body_0.text: Message sent!
                card.explorer_confirmation.body_1.text: Someone from our team will get back to you soon.
                card.explorer_form.actions_0.title: Send Message
                card.explorer_form.actions_1.title: Back
                card.explorer_form.body_0.text: Get in Touch
                card.explorer_form.body_1.text: We'd love to hear from you
                card.explorer_form.body_2.errorMessage: Name is required
                card.explorer_form.body_2.label: Name
                card.explorer_form.body_3.label: Company (optional)
                card.explorer_form.body_4.label: Job Title (optional)
                card.explorer_form.body_5.errorMessage: What brings you here? is required
                card.explorer_form.body_5.label: What brings you here?
                card.explorer_intro.actions_0.title: Continue →
                card.explorer_intro.actions_1.title: Back
                card.explorer_intro.body_0.text: Discover AI — Simply
                card.explorer_intro.body_1.text: No technical knowledge required
                card.explorer_intro.body_2.text: See live demos of AI digital workers in action.
                card.explorer_intro.body_3.text: Browse our knowledge base with plain-language explanations.
                card.explorer_intro.body_4.text: Understand how AI can transform your work — without the jargon.
                card.explorer_intro.body_5.text: '[Live Demos](https://demos.greentic.ai)'
                card.explorer_intro.body_6.text: '[Knowledge Base](https://docs.greentic.ai)'
                card.journalist_confirmation.body_0.text: Inquiry received!
                card.journalist_confirmation.body_1.text: Our communications team has been notified
                card.journalist_confirmation.body_2.text: You'll hear from us very shortly. We've also sent a WhatsApp notification to our team.
                card.journalist_form.actions_0.title: Submit Inquiry
                card.journalist_form.actions_1.title: Back
                card.journalist_form.body_0.text: Press Inquiry
                card.journalist_form.body_1.text: We'll get back to you ASAP
                card.journalist_form.body_2.errorMessage: Full Name is required
                card.journalist_form.body_2.label: Full Name
                card.journalist_form.body_3.errorMessage: Publication is required
                card.journalist_form.body_3.label: Publication
                card.journalist_form.body_4.errorMessage: Your Questions is required
                card.journalist_form.body_4.label: Your Questions
                card.journalist_form.body_5.label: WhatsApp Number
                card.journalist_form.body_5.placeholder: +31 6...
                card.journalist_intro.actions_0.title: Continue →
                card.journalist_intro.actions_1.title: Back
                card.journalist_intro.body_0.text: Press & Media
                card.journalist_intro.body_1.text: Get in touch with our communications team
                card.journalist_intro.body_2.text: For urgent press inquiries, please fill out the form below.
                card.journalist_intro.body_3.text: We aim to respond to all media requests within 2 hours.
                card.main_menu.actions_0.title: 🏢 Business Customer
                card.main_menu.actions_1.title: 🛠 Technical Partner
                card.main_menu.actions_2.title: 💼 Reseller Partner
                card.main_menu.actions_3.title: 👨‍💻 Developer
                card.main_menu.actions_4.title: 🌍 Non-technical Explorer
                card.main_menu.actions_5.title: 📰 Journalist / Press
                card.main_menu.actions_6.title: ❓ Other
