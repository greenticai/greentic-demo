{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Forecast Weather",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "${result.location.name}",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "TextBlock",
      "text": "${result.location.region}",
      "wrap": true,
      "isSubtle": true,
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "${result.location.country}",
      "wrap": true,
      "isSubtle": true,
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "Requested days: ${request.days}",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "**${result.forecast.forecastday[0].date}** - ${result.forecast.forecastday[0].day.condition.text}",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "High ${result.forecast.forecastday[0].day.maxtemp_c} C / Low ${result.forecast.forecastday[0].day.mintemp_c} C",
      "spacing": "None",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "TextBlock",
      "text": "**${result.forecast.forecastday[1].date}** - ${result.forecast.forecastday[1].day.condition.text}",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "High ${result.forecast.forecastday[1].day.maxtemp_c} C / Low ${result.forecast.forecastday[1].day.mintemp_c} C",
      "spacing": "None",
      "wrap": true,
      "isSubtle": true
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Run Another Query",
      "data": {}
    }
  ]
}
