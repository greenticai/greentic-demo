{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Weather Assistant",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Enter your WeatherAPI key and request values.",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "Input.Text",
      "id": "key",
      "label": "WeatherAPI Key",
      "placeholder": "Paste your API key",
      "isRequired": true,
      "errorMessage": "API key is required"
    },
    {
      "type": "Input.Text",
      "id": "q",
      "label": "City / Location",
      "placeholder": "Nairobi",
      "isRequired": true,
      "errorMessage": "Location is required",
      "value": "Nairobi"
    },
    {
      "type": "Input.Number",
      "id": "days",
      "label": "Forecast days",
      "placeholder": "3",
      "min": 1,
      "max": 10,
      "value": 3
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Get API Key",
      "url": "https://www.weatherapi.com/signup.aspx"
    },
    {
      "type": "Action.Submit",
      "title": "Current Weather",
      "data": {
        "operation": "get_weather",
        "method": "get_weather"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Forecast Weather",
      "data": {
        "operation": "get_forecast_weather",
        "method": "get_forecast_weather"
      }
    }
  ]
}
