{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Current Weather",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "${result.location.name}",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "TextBlock",
      "text": "${result.location.region}",
      "wrap": true,
      "isSubtle": true,
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "${result.location.country}",
      "wrap": true,
      "isSubtle": true,
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "${result.current.condition.text}",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Temperature",
          "value": "${result.current.temp_c} C / ${result.current.temp_f} F"
        },
        {
          "title": "Feels Like",
          "value": "${result.current.feelslike_c} C / ${result.current.feelslike_f} F"
        },
        {
          "title": "Humidity",
          "value": "${result.current.humidity}%"
        },
        {
          "title": "Wind",
          "value": "${result.current.wind_kph} kph (${result.current.wind_dir})"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Check Another Location",
      "data": {}
    }
  ]
}
