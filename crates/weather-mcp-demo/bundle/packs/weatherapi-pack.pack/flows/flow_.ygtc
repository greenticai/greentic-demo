id: flow_
type: messaging
start: render_weather_card
nodes:
  render_weather_card:
    component.exec:
      component: ai.greentic.component-adaptive-card
      operation: card
      input:
        card_source: asset
        card_spec:
          asset_path: assets/weather_forecast_card.json
        payload:
          request: "{{in}}"
          result: {}
    routing:
      - out: true
