{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "actions": [
    {
      "data": {
        "action_id": "back",
        "routeToCardId": "welcome_card"
      },
      "title": "{{i18n:cards.completion_card.actions.i0.title}}",
      "type": "Action.Submit"
    }
  ],
  "body": [
    {
      "items": [
        {
          "color": "Good",
          "horizontalAlignment": "Center",
          "size": "Large",
          "text": "{{i18n:cards.completion_card.body.i0.items.i0.text}}",
          "type": "TextBlock",
          "weight": "Bolder"
        },
        {
          "horizontalAlignment": "Center",
          "text": "Congratulations, {{employee_name}}! Your onboarding is now complete.",
          "type": "TextBlock",
          "wrap": true
        }
      ],
      "style": "good",
      "type": "Container"
    },
    {
      "items": [
        {
          "text": "{{i18n:cards.completion_card.body.i1.items.i0.text}}",
          "type": "TextBlock",
          "weight": "Bolder"
        },
        {
          "facts": [
            {
              "title": "{{i18n:cards.completion_card.body.i1.items.i1.facts.i0.title}}",
              "value": "{{employee_name}}"
            },
            {
              "title": "{{i18n:cards.completion_card.body.i1.items.i1.facts.i1.title}}",
              "value": "{{department}}"
            },
            {
              "title": "{{i18n:cards.completion_card.body.i1.items.i1.facts.i2.title}}",
              "value": "{{role}}"
            },
            {
              "title": "{{i18n:cards.completion_card.body.i1.items.i1.facts.i3.title}}",
              "value": "{{start_date}}"
            },
            {
              "title": "{{i18n:cards.completion_card.body.i1.items.i1.facts.i4.title}}",
              "value": "{{manager_name}}"
            }
          ],
          "type": "FactSet"
        }
      ],
      "spacing": "Medium",
      "style": "emphasis",
      "type": "Container"
    },
    {
      "items": [
        {
          "text": "{{i18n:cards.completion_card.body.i2.items.i0.text}}",
          "type": "TextBlock",
          "weight": "Bolder"
        },
        {
          "facts": [
            {
              "title": "{{i18n:cards.completion_card.body.i2.items.i1.facts.i0.title}}",
              "value": "Complete"
            },
            {
              "title": "{{i18n:cards.completion_card.body.i2.items.i1.facts.i1.title}}",
              "value": "Complete"
            },
            {
              "title": "{{i18n:cards.completion_card.body.i2.items.i1.facts.i2.title}}",
              "value": "Complete"
            }
          ],
          "type": "FactSet"
        }
      ],
      "spacing": "Small",
      "style": "emphasis",
      "type": "Container"
    },
    {
      "items": [
        {
          "text": "{{i18n:cards.completion_card.body.i3.items.i0.text}}",
          "type": "TextBlock",
          "weight": "Bolder"
        },
        {
          "text": "{{i18n:cards.completion_card.body.i3.items.i1.text}}",
          "type": "TextBlock",
          "wrap": true
        }
      ],
      "spacing": "Medium",
      "type": "Container"
    },
    {
      "isSubtle": true,
      "size": "Small",
      "spacing": "Medium",
      "text": "{{i18n:cards.completion_card.body.i4.text}}",
      "type": "TextBlock",
      "wrap": true
    }
  ],
  "type": "AdaptiveCard",
  "version": "1.3"
}