{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "actions": [
    {
      "data": {
        "action_id": "submit_employee"
      },
      "style": "positive",
      "title": "{{i18n:cards.employee_form_card.actions.i0.title}}",
      "type": "Action.Submit"
    },
    {
      "data": {
        "action_id": "cancel",
        "routeToCardId": "welcome_card"
      },
      "style": "default",
      "title": "{{i18n:cards.employee_form_card.actions.i1.title}}",
      "type": "Action.Submit"
    }
  ],
  "body": [
    {
      "size": "Large",
      "text": "{{i18n:cards.employee_form_card.body.i0.text}}",
      "type": "TextBlock",
      "weight": "Bolder"
    },
    {
      "isSubtle": true,
      "text": "Welcome to {{company_name}}! Please fill in your information below.",
      "type": "TextBlock",
      "wrap": true
    },
    {
      "items": [
        {
          "spacing": "Small",
          "text": "{{i18n:cards.employee_form_card.body.i2.items.i0.text}}",
          "type": "TextBlock",
          "weight": "Bolder"
        },
        {
          "errorMessage": "{{i18n:cards.employee_form_card.body.i2.items.i1.errormessage}}",
          "id": "full_name",
          "isRequired": true,
          "label": "{{i18n:cards.employee_form_card.body.i2.items.i1.label}}",
          "placeholder": "{{i18n:cards.employee_form_card.body.i2.items.i1.placeholder}}",
          "type": "Input.Text"
        },
        {
          "errorMessage": "{{i18n:cards.employee_form_card.body.i2.items.i2.errormessage}}",
          "id": "email",
          "isRequired": true,
          "label": "{{i18n:cards.employee_form_card.body.i2.items.i2.label}}",
          "placeholder": "{{i18n:cards.employee_form_card.body.i2.items.i2.placeholder}}",
          "style": "Email",
          "type": "Input.Text"
        }
      ],
      "style": "emphasis",
      "type": "Container"
    },
    {
      "items": [
        {
          "spacing": "Small",
          "text": "{{i18n:cards.employee_form_card.body.i3.items.i0.text}}",
          "type": "TextBlock",
          "weight": "Bolder"
        },
        {
          "choices": [
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i0.title}}",
              "value": "Engineering"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i1.title}}",
              "value": "Product"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i2.title}}",
              "value": "Design"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i3.title}}",
              "value": "Marketing"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i4.title}}",
              "value": "Sales"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i5.title}}",
              "value": "Finance"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i6.title}}",
              "value": "Human Resources"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i7.title}}",
              "value": "Legal"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i8.title}}",
              "value": "Operations"
            },
            {
              "title": "{{i18n:cards.employee_form_card.body.i3.items.i1.choices.i9.title}}",
              "value": "Customer Support"
            }
          ],
          "id": "department",
          "isRequired": true,
          "label": "{{i18n:cards.employee_form_card.body.i3.items.i1.label}}",
          "type": "Input.ChoiceSet",
          "value": "{{default_department}}"
        },
        {
          "id": "role",
          "label": "{{i18n:cards.employee_form_card.body.i3.items.i2.label}}",
          "placeholder": "{{i18n:cards.employee_form_card.body.i3.items.i2.placeholder}}",
          "type": "Input.Text"
        },
        {
          "id": "start_date",
          "label": "{{i18n:cards.employee_form_card.body.i3.items.i3.label}}",
          "type": "Input.Date"
        },
        {
          "id": "manager_name",
          "label": "{{i18n:cards.employee_form_card.body.i3.items.i4.label}}",
          "placeholder": "{{i18n:cards.employee_form_card.body.i3.items.i4.placeholder}}",
          "type": "Input.Text"
        }
      ],
      "style": "emphasis",
      "type": "Container"
    }
  ],
  "type": "AdaptiveCard",
  "version": "1.3"
}