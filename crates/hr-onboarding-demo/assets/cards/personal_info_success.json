{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "actions": [
    {
      "data": {
        "action_id": "goto_upload_docs",
        "routeToCardId": "upload_docs"
      },
      "style": "positive",
      "title": "Next: Upload Documents",
      "type": "Action.Submit"
    },
    {
      "data": {
        "action_id": "goto_welcome",
        "routeToCardId": "welcome"
      },
      "title": "Back to Menu",
      "type": "Action.Submit"
    }
  ],
  "body": [
    {
      "columns": [
        {
          "items": [
            {
              "color": "Good",
              "name": "CheckmarkCircle",
              "size": "Large",
              "style": "Filled",
              "type": "Icon"
            }
          ],
          "type": "Column",
          "verticalContentAlignment": "Center",
          "width": "auto"
        },
        {
          "items": [
            {
              "color": "Good",
              "size": "ExtraLarge",
              "text": "Personal Info Saved",
              "type": "TextBlock",
              "weight": "Bolder"
            },
            {
              "text": "Your information has been submitted. Onboarding just got easier!",
              "type": "TextBlock",
              "wrap": true
            }
          ],
          "type": "Column",
          "verticalContentAlignment": "Center",
          "width": "stretch"
        }
      ],
      "type": "ColumnSet"
    },
    {
      "facts": [
        {
          "title": "Name",
          "value": "${full_name}"
        },
        {
          "title": "Email",
          "value": "${email}"
        },
        {
          "title": "Department",
          "value": "${department}"
        },
        {
          "title": "Start",
          "value": "${start_date}"
        }
      ],
      "type": "FactSet"
    }
  ],
  "greentic": {
    "cardId": "personal_info_success",
    "flow": "hr_onboarding_demo"
  },
  "speak": "Your personal information has been successfully saved.",
  "type": "AdaptiveCard",
  "version": "1.6"
}