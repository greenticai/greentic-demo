{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "actions": [
    {
      "data": {
        "action_id": "submit_access_request"
      },
      "style": "positive",
      "title": "{{i18n:cards.access_request_card.actions.i0.title}}",
      "type": "Action.Submit"
    },
    {
      "data": {
        "action_id": "back",
        "routeToCardId": "welcome_card"
      },
      "title": "{{i18n:cards.access_request_card.actions.i1.title}}",
      "type": "Action.Submit"
