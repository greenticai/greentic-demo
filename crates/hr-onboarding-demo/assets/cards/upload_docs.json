{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "actions": [
    {
      "title": "Upload Documents Online",
      "type": "Action.OpenUrl",
      "url": "https://greentic.docs/upload"
    },
    {
      "data": {
        "action_id": "goto_upload_success",
        "routeToCardId": "upload_success"
      },
      "style": "positive",
      "title": "Mark as Done",
      "type": "Action.Submit"
    },
    {
      "data": {
        "action_id": "goto_checklist",
        "routeToCardId": "checklist"
      },
      "title": "Back to Checklist",
      "type": "Action.Submit"
    }
  ],
  "body": [
    {
      "color": "Accent",
      "size": "Large",
      "text": "Step 3 of 4 – Upload Required Documents",
      "type": "TextBlock",
      "weight": "Bolder"
    },
    {
      "bleed": true,
      "items": [
        {
          "text": "Please upload these documents. Accepted: PDF, JPG, PNG up to 5MB each.",
          "type": "TextBlock",
          "wrap": true
        },
        {
          "facts": [
            {
              "title": "1. Government ID",
              "value": "[Upload](https://greentic.docs/upload/id)"
            },
            {
              "title": "2. Tax Form NPWP",
              "value": "[Upload](https://greentic.docs/upload/tax)"
            },
            {
              "title": "3. Employment Contract",
              "value": "[Upload](https://greentic.docs/upload/contract)"
            }
          ],
          "type": "FactSet"
        }
      ],
      "style": "emphasis",
      "type": "Container"
    },
    {
      "color": "Good",
      "isSubtle": true,
      "text": "Status: 2 of 3 uploaded",
      "type": "TextBlock"
    }
  ],
  "greentic": {
    "cardId": "upload_docs",
    "flow": "hr_onboarding_demo"
  },
  "speak": "Document upload portal. Upload Government ID, Tax Form, Employment Contract.",
  "type": "AdaptiveCard",
  "version": "1.6"
}