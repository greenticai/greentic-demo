{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "body": [
    {
      "columns": [
        {
          "items": [
            {
              "altText": "Briefcase icon for HR portal",
              "size": "Medium",
              "type": "Image",
              "url": "https://img.icons8.com/fluency/96/briefcase.png"
            }
          ],
          "type": "Column",
          "verticalContentAlignment": "Center",
          "width": "auto"
        },
        {
          "items": [
            {
              "color": "Accent",
              "size": "ExtraLarge",
              "text": "HR Onboarding Portal",
              "type": "TextBlock",
              "weight": "Bolder"
            },
            {
              "isSubtle": true,
              "size": "Default",
              "text": "Welcome to Greentic! Let’s get you started 🚀",
              "type": "TextBlock",
              "wrap": true
            }
          ],
          "type": "Column",
          "verticalContentAlignment": "Center",
          "width": "stretch"
        },
        {
          "items": [
            {
              "appearance": "tint",
              "style": "informative",
              "text": "Demo mode",
              "type": "Badge"
            }
          ],
          "type": "Column",
          "verticalContentAlignment": "Center",
          "width": "auto"
        }
      ],
      "type": "ColumnSet"
    },
    {
      "bleed": true,
      "items": [
        {
          "text": "Onboarding Progress Summary",
          "type": "TextBlock",
          "weight": "Bolder"
        },
        {
          "facts": [
            {
              "title": "Personal Info:",
              "value": "Completed"
            },
            {
              "title": "Documents:",
              "value": "2 of 3 uploaded"
            },
            {
              "title": "IT Setup:",
              "value": "In Progress"
            },
            {
              "title": "Orientation:",
              "value": "Booked"
            }
          ],
          "type": "FactSet"
        }
      ],
      "spacing": "Medium",
      "style": "good",
      "type": "Container"
    },
    {
      "actions": [
        {
          "data": {
            "action_id": "goto_personal_info",
            "routeToCardId": "personal_info"
          },
          "style": "positive",
          "title": "📝 Fill Personal Info",
          "type": "Action.Submit"
        },
        {
          "data": {
            "action_id": "goto_checklist",
            "routeToCardId": "checklist"
          },
          "title": "📋 Task Checklist",
          "type": "Action.Submit"
        },
        {
          "data": {
            "action_id": "goto_upload_docs",
            "routeToCardId": "upload_docs"
          },
          "title": "📄 Upload Documents",
          "type": "Action.Submit"
        },
        {
          "data": {
            "action_id": "goto_it_progress",
            "routeToCardId": "it_progress"
          },
          "title": "💻 IT Setup Progress",
          "type": "Action.Submit"
        },
        {
          "data": {
            "action_id": "goto_buddy_intro",
            "routeToCardId": "buddy_intro"
          },
          "title": "👤 Meet Your Buddy",
          "type": "Action.Submit"
        }
      ],
      "type": "ActionSet"
    }
  ],
  "greentic": {
    "cardId": "welcome",
    "flow": "hr_onboarding_demo"
  },
  "speak": "HR Onboarding Portal main menu. Welcome to Greentic! Begin onboarding, view task checklist, upload documents, see IT setup progress, or talk to your onboarding buddy.",
  "type": "AdaptiveCard",
  "version": "1.6"
}