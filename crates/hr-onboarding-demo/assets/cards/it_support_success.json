{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "actions": [
    {
      "data": {
        "action_id": "goto_it_progress",
        "routeToCardId": "it_progress"
      },
      "title": "Back to IT Progress",
      "type": "Action.Submit"
    }
  ],
  "body": [
    {
      "bleed": true,
      "items": [
        {
          "columns": [
            {
              "items": [
                {
                  "color": "Good",
                  "name": "CheckmarkCircle",
                  "size": "Large",
                  "style": "Filled",
                  "type": "Icon"
                }
              ],
              "type": "Column",
              "verticalContentAlignment": "Center",
              "width": "auto"
            },
            {
              "items": [
                {
                  "color": "Good",
                  "size": "Large",
                  "text": "Request Sent",
                  "type": "TextBlock",
                  "weight": "Bolder"
                },
                {
                  "text": "Your message was sent to IT:\n\n\"${support_message}\"",
                  "type": "TextBlock",
                  "wrap": true
                }
              ],
              "type": "Column",
              "width": "stretch"
            }
          ],
          "type": "ColumnSet"
        },
        {
          "color": "Accent",
          "spacing": "Medium",
          "text": "Expect a reply within 1 business day.",
          "type": "TextBlock",
          "wrap": true
        }
      ],
      "style": "good",
      "type": "Container"
    }
  ],
  "greentic": {
    "cardId": "it_support_success",
    "flow": "hr_onboarding_demo"
  },
  "speak": "Your IT request has been received. Confirmation.",
  "type": "AdaptiveCard",
  "version": "1.6"
}