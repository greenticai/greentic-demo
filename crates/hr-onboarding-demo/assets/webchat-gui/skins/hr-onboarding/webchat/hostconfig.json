{
  "fontFamily": "'Poppins', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif",
  "spacing": {
    "small": 6,
    "default": 12,
    "medium": 16,
    "large": 20
  },
  "containerStyles": {
    "default": {
      "foregroundColors": {
        "default": { "default": "#0F2A23", "subtle": "#5A6B66" },
        "accent": { "default": "#22C39E", "subtle": "#1BA886" },
        "good": { "default": "#22C39E", "subtle": "#1BA886" },
        "warning": { "default": "#F59E0B", "subtle": "#B45309" },
        "attention": { "default": "#EF4444", "subtle": "#B91C1C" }
      }
    },
    "emphasis": {
      "backgroundColor": "#F2FBF8",
      "foregroundColors": {
        "default": { "default": "#0F2A23", "subtle": "#5A6B66" },
        "accent": { "default": "#22C39E", "subtle": "#1BA886" }
      }
    }
  }
}
