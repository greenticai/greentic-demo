{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Onboarding Checklist"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Jane Smith - Engineering",
              "isSubtle": true
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "2/5 Complete",
              "weight": "Bolder",
              "color": "Good"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Progress: 40%",
      "spacing": "Small"
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "$data": "",
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "\u2705",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Task",
                  "weight": "Bolder"
                },
                {
                  "type": "TextBlock",
                  "text": "Task description",
                  "isSubtle": true,
                  "wrap": true,
                  "size": "Small"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Done",
                  "isSubtle": true,
                  "size": "Small"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Upload Documents",
          "style": "positive",
          "data": {
            "action_id": "upload_documents",
            "routeToCardId": "document_upload_card"
          }
        },
        {
          "type": "Action.Submit",
          "title": "Request Access",
          "data": {
            "action_id": "request_access",
            "routeToCardId": "access_request_card"
          }
        }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Back to Menu",
          "data": {
            "action_id": "back",
            "routeToCardId": "welcome_card"
          }
        }
      ]
    }
  ]
}