{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "Required Documents"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Employee: {{employee_name}}",
              "isSubtle": true
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "{{uploaded_count}}/{{total_count}} Submitted",
              "weight": "Bolder",
              "color": "Good"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Please submit the following documents to complete your onboarding.",
      "wrap": true,
      "isSubtle": true,
      "spacing": "Small"
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "weight": "Bolder",
                  "text": "Government-Issued Photo ID"
                },
                {
                  "type": "TextBlock",
                  "text": "Passport, driver's license, or national ID card",
                  "isSubtle": true,
                  "size": "Small",
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.Submit",
                      "title": "Upload",
                      "data": {
                        "action_id": "upload_government_id"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Small",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "weight": "Bolder",
                  "text": "Tax Form W-4"
                },
                {
                  "type": "TextBlock",
                  "text": "Federal tax withholding form",
                  "isSubtle": true,
                  "size": "Small",
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.Submit",
                      "title": "Upload",
                      "data": {
                        "action_id": "upload_tax_form"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Small",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "weight": "Bolder",
                  "text": "Signed Employment Contract"
                },
                {
                  "type": "TextBlock",
                  "text": "Your signed offer letter and employment agreement",
                  "isSubtle": true,
                  "size": "Small",
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.Submit",
                      "title": "Upload",
                      "data": {
                        "action_id": "upload_contract"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Small",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "weight": "Bolder",
                  "text": "Emergency Contact Form"
                },
                {
                  "type": "TextBlock",
                  "text": "Emergency contact details and medical information",
                  "isSubtle": true,
                  "size": "Small",
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.Submit",
                      "title": "Upload",
                      "data": {
                        "action_id": "upload_emergency_contact"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Small",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "weight": "Bolder",
                  "text": "Direct Deposit Authorization"
                },
                {
                  "type": "TextBlock",
                  "text": "Bank account details for payroll",
                  "isSubtle": true,
                  "size": "Small",
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.Submit",
                      "title": "Upload",
                      "data": {
                        "action_id": "upload_direct_deposit"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Small",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "weight": "Bolder",
                  "text": "Non-Disclosure Agreement"
                },
                {
                  "type": "TextBlock",
                  "text": "Confidentiality and non-disclosure agreement",
                  "isSubtle": true,
                  "size": "Small",
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "ActionSet",
                  "actions": [
                    {
                      "type": "Action.Submit",
                      "title": "Upload",
                      "data": {
                        "action_id": "upload_nda"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Back to Menu",
          "data": {
            "action_id": "back",
            "routeToCardId": "welcome_card"
          }
        }
      ]
    }
  ]
}