{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "System Access Request"
    },
    {
      "type": "TextBlock",
      "text": "Jane Smith - Engineering (Software Engineer)",
      "isSubtle": true,
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Systems that will be provisioned for your role:",
      "wrap": true,
      "spacing": "Medium"
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Communication & Collaboration"
        },
        {
          "type": "FactSet",
          "facts": [
            { "title": "Corporate Email", "value": "Outlook/Gmail" },
            { "title": "Slack", "value": "Team messaging" }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Development & Project Management"
        },
        {
          "type": "FactSet",
          "facts": [
            { "title": "GitHub", "value": "Source code repositories" },
            { "title": "Jira", "value": "Project tracking" }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Infrastructure & Physical Access"
        },
        {
          "type": "FactSet",
          "facts": [
            { "title": "VPN", "value": "Remote network access" },
            { "title": "Building Access", "value": "Badge/keycard" }
          ]
        }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Submit Access Request",
          "style": "positive",
          "data": {
            "action_id": "submit_access",
            "routeToCardId": "completion_card"
          }
        },
        {
          "type": "Action.Submit",
          "title": "Back to Menu",
          "data": {
            "action_id": "back",
            "routeToCardId": "welcome_card"
          }
        }
      ]
    }
  ]
}
