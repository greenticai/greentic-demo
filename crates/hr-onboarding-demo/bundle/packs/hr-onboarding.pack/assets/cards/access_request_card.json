{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "System Access Request"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "{{employee_name}} - {{department}} ({{role}})",
              "isSubtle": true,
              "wrap": true
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "{{provisioned_count}}/{{total_count}} Active",
              "weight": "Bolder",
              "color": "Good"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Select the systems you need access to for your role.",
      "wrap": true,
      "isSubtle": true,
      "spacing": "Small"
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Communication & Collaboration",
          "spacing": "Small"
        },
        {
          "type": "Input.Toggle",
          "id": "corporate_email",
          "title": "Corporate Email (Outlook/Gmail)",
          "value": "true",
          "valueOn": "true",
          "valueOff": "false"
        },
        {
          "type": "Input.Toggle",
          "id": "slack",
          "title": "Slack (Team messaging)",
          "value": "true",
          "valueOn": "true",
          "valueOff": "false"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Small",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Development & Project Management",
          "spacing": "Small"
        },
        {
          "type": "Input.Toggle",
          "id": "github",
          "title": "GitHub (Source code repositories)",
          "value": "false",
          "valueOn": "true",
          "valueOff": "false"
        },
        {
          "type": "Input.Toggle",
          "id": "jira",
          "title": "Jira (Project tracking)",
          "value": "false",
          "valueOn": "true",
          "valueOff": "false"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Small",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Infrastructure & Physical Access",
          "spacing": "Small"
        },
        {
          "type": "Input.Toggle",
          "id": "vpn",
          "title": "VPN (Remote network access)",
          "value": "true",
          "valueOn": "true",
          "valueOff": "false"
        },
        {
          "type": "Input.Toggle",
          "id": "building_access",
          "title": "Building Access (Badge/keycard)",
          "value": "true",
          "valueOn": "true",
          "valueOff": "false"
        }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Submit Access Request",
          "style": "positive",
          "data": {
            "action_id": "submit_access_request"
          }
        },
        {
          "type": "Action.Submit",
          "title": "Back to Menu",
          "data": {
            "action_id": "back",
            "routeToCardId": "welcome_card"
          }
        }
      ]
    }
  ]
}