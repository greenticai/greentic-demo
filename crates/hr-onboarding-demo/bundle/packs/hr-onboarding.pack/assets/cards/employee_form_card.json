{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "New Employee Registration"
    },
    {
      "type": "TextBlock",
      "text": "Welcome to {{company_name}}! Please fill in your information below.",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Personal Information",
          "spacing": "Small"
        },
        {
          "type": "Input.Text",
          "id": "full_name",
          "label": "Full Name",
          "placeholder": "e.g., Jane Smith",
          "isRequired": true,
          "errorMessage": "Full name is required"
        },
        {
          "type": "Input.Text",
          "id": "email",
          "label": "Work Email",
          "placeholder": "e.g., jane.smith@acmecorp.com",
          "isRequired": true,
          "errorMessage": "Work email is required",
          "style": "Email"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Role Information",
          "spacing": "Small"
        },
        {
          "type": "Input.ChoiceSet",
          "id": "department",
          "label": "Department",
          "value": "{{default_department}}",
          "isRequired": true,
          "choices": [
            { "title": "Engineering", "value": "Engineering" },
            { "title": "Product", "value": "Product" },
            { "title": "Design", "value": "Design" },
            { "title": "Marketing", "value": "Marketing" },
            { "title": "Sales", "value": "Sales" },
            { "title": "Finance", "value": "Finance" },
            { "title": "Human Resources", "value": "Human Resources" },
            { "title": "Legal", "value": "Legal" },
            { "title": "Operations", "value": "Operations" },
            { "title": "Customer Support", "value": "Customer Support" }
          ]
        },
        {
          "type": "Input.Text",
          "id": "role",
          "label": "Job Title / Role",
          "placeholder": "e.g., Senior Software Engineer"
        },
        {
          "type": "Input.Date",
          "id": "start_date",
          "label": "Start Date"
        },
        {
          "type": "Input.Text",
          "id": "manager_name",
          "label": "Reporting Manager",
          "placeholder": "e.g., John Doe"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Submit Registration",
      "style": "positive",
      "data": {
        "action_id": "submit_employee"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Cancel",
      "style": "default",
      "data": {
        "action_id": "cancel"
      }
    }
  ]
}
