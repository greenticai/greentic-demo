{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "New Employee Registration"
    },
    {
      "type": "TextBlock",
      "text": "Welcome to Acme Corp! Please fill in your information below.",
      "wrap": true,
      "isSubtle": true
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Personal Information"
        },
        {
          "type": "FactSet",
          "facts": [
            { "title": "Full Name", "value": "Jane Smith" },
            { "title": "Work Email", "value": "jane.smith@acmecorp.com" }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Role Information"
        },
        {
          "type": "FactSet",
          "facts": [
            { "title": "Department", "value": "Engineering" },
            { "title": "Job Title", "value": "Software Engineer" },
            { "title": "Start Date", "value": "April 15, 2026" },
            { "title": "Manager", "value": "John Doe" }
          ]
        }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.Submit",
          "title": "Confirm Registration",
          "style": "positive",
          "data": {
            "action_id": "submit_registration",
            "routeToCardId": "onboarding_checklist_card"
          }
        },
        {
          "type": "Action.Submit",
          "title": "Back to Menu",
          "data": {
            "action_id": "back",
            "routeToCardId": "welcome_card"
          }
        }
      ]
    }
  ]
}
